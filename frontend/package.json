{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint:css": "stylelint \"src/**/*.component.css\"",
    "prepare": "cd .. && husky frontend/.husky",
    "e2e:up": "docker compose -f ../docker-compose.test.yml up -d --build --wait && npm run e2e:seed && echo \"E2E stack ready: API http://localhost:8080 (DB on host port 5433)\"",
    "e2e:seed": "docker compose -f ../docker-compose.test.yml exec -T db psql -U eventlineup -d eventlineup < ../backend/seed/seed_test.sql",
    "e2e:reset": "npm run e2e:seed",
    "e2e:token": "cd ../backend && JWT_SECRET=e2e-test-jwt-secret-do-not-use-in-prod-0123456789 go run ./cmd/mintdevtoken",
    "e2e:logs": "docker compose -f ../docker-compose.test.yml logs -f",
    "e2e:down": "docker compose -f ../docker-compose.test.yml down -v",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report"
  },
  "private": true,
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@ngx-translate/core": "^18.0.0",
    "@ngx-translate/http-loader": "^18.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.0",
    "@playwright/test": "^1.61.1",
    "autoprefixer": "^10.5.2",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.16",
    "prettier": "^3.9.3",
    "stylelint": "^17.14.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
