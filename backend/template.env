# Copy to backend/.env and fill in. backend/.env is gitignored — never commit real secrets.

# Postgres connection string (matches docker-compose.yml defaults for local dev)
DATABASE_URL=postgresql://eventlineup:eventlineup@localhost:5432/eventlineup

# HTTP port the API listens on
PORT=8080

# Allowed CORS origin for the frontend
FRONTEND_URL=http://localhost:4200

# HMAC secret used to sign/verify organizer JWTs. Minimum 32 characters.
# Generate one with: openssl rand -base64 48
JWT_SECRET=replace-with-a-random-string-at-least-32-chars-long
