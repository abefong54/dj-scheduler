# Backend environment template.
# Copy to backend/.env and fill in real values. backend/.env is gitignored —
# never commit real secrets.

# --- Database -------------------------------------------------------------
# Postgres connection string (matches docker-compose.yml defaults for local dev)
DATABASE_URL=postgresql://eventlineup:eventlineup@localhost:5432/eventlineup

# --- HTTP server ----------------------------------------------------------
# Port the API listens on
PORT=8080

# Allowed CORS origin for the frontend
FRONTEND_URL=http://localhost:4200

# --- Cookies --------------------------------------------------------------
# Marks auth cookies Secure (HTTPS-only). Leave false for local http dev; set
# COOKIE_SECURE=true in production (Railway), where the API is served over HTTPS.
COOKIE_SECURE=false

# --- Auth: JWT (US-000) ---------------------------------------------------
# HMAC secret used to sign/verify organizer JWTs. Minimum 32 characters.
# Generate one with: openssl rand -base64 48
JWT_SECRET=replace-with-a-random-string-at-least-32-chars-long

# --- Auth: Google SSO (US-001) --------------------------------------------
# OAuth 2.0 Web Application client from Google Cloud Console
# (APIs & Services -> Credentials -> Create Credentials -> OAuth client ID).
# Add the redirect URL below to the client's "Authorized redirect URIs".
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# --- Auth: LINE Notify token encryption (US-006) --------------------------
# REQUIRED — the server refuses to start without it. AES-256 key as a 64-char
# hex string used to encrypt per-event LINE Notify tokens at rest.
# Generate one with: openssl rand -hex 32
LINE_NOTIFY_ENCRYPTION_KEY=replace-with-64-hex-chars-openssl-rand-hex-32
